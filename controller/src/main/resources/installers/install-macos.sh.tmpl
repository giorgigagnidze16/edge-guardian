#!/usr/bin/env bash
# EdgeGuardian agent installer (macOS). Generated per-token.
set -euo pipefail

CONTROLLER_URL="{{CONTROLLER_URL}}"
BROKER_URL="{{BROKER_URL}}"
MTLS_BROKER_URL="{{MTLS_BROKER_URL}}"
BOOTSTRAP_PASSWORD="{{BOOTSTRAP_PASSWORD}}"
ENROLLMENT_TOKEN="{{ENROLLMENT_TOKEN}}"
BINARY_URL="{{BINARY_URL}}"
AGENT_VERSION="{{AGENT_VERSION}}"

INSTALL_DIR="/usr/local/bin"
CONFIG_DIR="/etc/edgeguardian"
DATA_DIR="/var/lib/edgeguardian"
LOG_FILE="/var/log/edgeguardian-agent.log"
PLIST_PATH="/Library/LaunchDaemons/com.edgeguardian.agent.plist"
SERVICE_LABEL="com.edgeguardian.agent"
BINARY_PATH="$INSTALL_DIR/edgeguardian-agent"
CONFIG_PATH="$CONFIG_DIR/agent.yaml"
TOTAL_STEPS=5

LOGO=$(cat <<'EGLOGO'
{{LOGO}}
EGLOGO
)

if [[ -t 1 ]]; then
  C_RESET='\033[0m'; C_GREEN='\033[1;32m'; C_CYAN='\033[1;36m'
  C_GRAY='\033[90m'; C_YELLOW='\033[33m'; C_RED='\033[1;31m'; C_WHITE='\033[1;37m'
else
  C_RESET=''; C_GREEN=''; C_CYAN=''; C_GRAY=''; C_YELLOW=''; C_RED=''; C_WHITE=''
fi

banner()  { printf "\n${C_GREEN}%s${C_RESET}\n\n  ${C_WHITE}EdgeGuardian Agent Installer${C_RESET}\n  ${C_GRAY}Version %s${C_RESET}\n  ${C_GRAY}----------------------------------------------------${C_RESET}\n" "$LOGO" "$AGENT_VERSION"; }
step()    { printf "\n  ${C_CYAN}[%s/%s] %s${C_RESET}\n" "$1" "$TOTAL_STEPS" "$2"; }
substep() { printf "        ${C_GRAY}- %s${C_RESET}\n" "$1"; }
ok()      { printf "        ${C_GREEN}OK${C_RESET} %s\n" "$1"; }

on_error() {
  local ec=$?
  printf "\n  ${C_RED}*** INSTALL FAILED ***${C_RESET} (exit %s)\n" "$ec"
  if [[ -f "$LOG_FILE" ]]; then
    printf "\n  ${C_YELLOW}Last 20 lines of %s:${C_RESET}\n" "$LOG_FILE"
    tail -n 20 "$LOG_FILE" 2>/dev/null | sed 's/^/    /' || true
  fi
  exit "$ec"
}
trap on_error ERR

if [[ $EUID -ne 0 ]]; then
  echo "This installer must run as root (sudo)." >&2
  exit 1
fi

banner

step 1 "Preparing installation directories"
mkdir -p "$INSTALL_DIR" "$CONFIG_DIR" "$DATA_DIR"
touch "$LOG_FILE"
chown root:wheel "$LOG_FILE"
chmod 0640 "$LOG_FILE"
substep "$INSTALL_DIR"
substep "$CONFIG_DIR"
substep "$DATA_DIR"
substep "$LOG_FILE"
ok "Directories ready"

step 2 "Downloading agent binary"
substep "Source:      $BINARY_URL"
substep "Destination: $BINARY_PATH"
# Retry absorbs the occasional port-forward hiccup instead of aborting the install.
curl -fsSL --retry 4 --retry-delay 2 --retry-connrefused "$BINARY_URL" -o "$BINARY_PATH"
chmod 0755 "$BINARY_PATH"
ok "Downloaded $(du -h "$BINARY_PATH" | awk '{print $1}')"

step 3 "Writing configuration"
DEVICE_ID="$(scutil --get ComputerName 2>/dev/null | tr -d ' ' || hostname)-$(date +%s)"
CONTROLLER_HOST="$(echo "$CONTROLLER_URL" | sed -E 's#https?://##; s#:[0-9]+$##; s#/.*$##')"
CONTROLLER_PORT="$(echo "$CONTROLLER_URL" | sed -nE 's#.*:([0-9]+).*#\1#p')"
CONTROLLER_PORT="${CONTROLLER_PORT:-443}"
substep "Device ID:  $DEVICE_ID"
substep "Controller: ${CONTROLLER_HOST}:${CONTROLLER_PORT}"
substep "MQTT:       $MTLS_BROKER_URL"
substep "Config:     $CONFIG_PATH"

cat > "$CONFIG_PATH" <<EOF
device_id: ${DEVICE_ID}
controller_address: ${CONTROLLER_HOST}
controller_port: ${CONTROLLER_PORT}
data_dir: ${DATA_DIR}
reconcile_interval_seconds: 30
log_level: info
auth:
  enrollment_token: ${ENROLLMENT_TOKEN}
mqtt:
  broker_url: ${BROKER_URL}
  username: bootstrap
  password: ${BOOTSTRAP_PASSWORD}
  topic_root: edgeguardian
  mtls_broker_url: ${MTLS_BROKER_URL}
  ca_cert_path: ${DATA_DIR}/identity/ca.crt
  identity_cert_path: ${DATA_DIR}/identity/identity.crt
  identity_key_path: ${DATA_DIR}/identity/identity.key
EOF
chmod 0600 "$CONFIG_PATH"
ok "Configuration written"

step 4 "Installing LaunchDaemon"
substep "Label:     $SERVICE_LABEL"
substep "Plist:     $PLIST_PATH"
cat > "$PLIST_PATH" <<'EOF'
{{LAUNCHD_PLIST}}
EOF
chown root:wheel "$PLIST_PATH"
chmod 0644 "$PLIST_PATH"
ok "LaunchDaemon registered"

step 5 "Starting service"
# bootout first so re-installs don't fail with "service already loaded".
launchctl bootout system "$PLIST_PATH" 2>/dev/null || true
launchctl bootstrap system "$PLIST_PATH"
launchctl enable "system/${SERVICE_LABEL}"
launchctl kickstart -k "system/${SERVICE_LABEL}"
sleep 2
pid="$(launchctl print "system/${SERVICE_LABEL}" 2>/dev/null | awk -F '= ' '/pid =/{print $2; exit}' || true)"
substep "PID: ${pid:-<not running>}"
if [[ -z "${pid:-}" || "$pid" == "0" ]]; then
  echo "Service failed to start" >&2
  false
fi
ok "Agent is running"

printf "\n  ${C_GRAY}----------------------------------------------------${C_RESET}\n"
printf "  ${C_GREEN}Install succeeded. EdgeGuardian Agent v%s is running.${C_RESET}\n" "$AGENT_VERSION"
printf "  ${C_GRAY}Service:  %s${C_RESET}\n" "$SERVICE_LABEL"
printf "  ${C_GRAY}Config:   %s${C_RESET}\n" "$CONFIG_PATH"
printf "  ${C_GRAY}Data dir: %s${C_RESET}\n" "$DATA_DIR"
printf "  ${C_GRAY}Logs:     tail -f %s${C_RESET}\n\n" "$LOG_FILE"
